{
  "version": 2,
  "buildCommand": "pip install --extra-index-url https://download.pytorch.org/whl/cpu --only-binary :all: -r requirements-api.txt",
  "installCommand": "pip install --extra-index-url https://download.pytorch.org/whl/cpu --only-binary :all: -r requirements-api.txt",
  "builds": [
    {
      "src": "api_server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api_server.py"
    }
  ]
}
